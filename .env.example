# Example environment variables for the local Docker Compose stack.
# Copy to .env (git-ignored) and edit. NEVER commit real secrets.
# The docker-compose.yml already provides sane defaults; these override them.

# Application
ENVIRONMENT=local
LOG_LEVEL=INFO
WORKERS=4
HOST=0.0.0.0
PORT=8000

# Database (local stack only; AWS uses Secrets Manager)
DATABASE_URL=postgresql+psycopg://shop:shop@postgres:5432/shop
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_SECONDS=5
DB_RETRY_ATTEMPTS=3

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=30

# Incident simulation flags (set to non-zero to simulate)
INJECT_LATENCY_MS=0
INJECT_FAILURE_RATE=0
HIGH_CPU_LOAD=false

# --- AWS deployment variables (used by Terraform, NOT committed) ---
# AWS_REGION=us-east-1
# TF_VAR_ami_id=ami-0REPLACE
# TF_VAR_ecr_image=123456789012.dkr.ecr.us-east-1.amazonaws.com/sre-platform:latest
# TF_VAR_redis_auth_token=REPLACE_WITH_SECRET
# TF_VAR_alert_email=you@example.com
