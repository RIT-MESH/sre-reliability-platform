# Example variable values for the dev environment.
# Copy to terraform.tfvars and edit. NEVER commit real secrets.
region            = "us-east-1"
vpc_cidr          = "10.20.0.0/16"
db_name           = "shop"
ami_id            = "ami-0 REPLACE_WITH_AMAZON_LINUX_2023_AMI_ID"
ecr_image         = "123456789012.dkr.ecr.us-east-1.amazonaws.com/sre-platform:latest"
# redis_auth_token is sensitive; pass it via:
#   export TF_VAR_redis_auth_token="$(aws secretsmanager get-secret-value ...)"
alert_email       = "you@example.com"
